# ─── Server ───────────────────────────────────────────────────────────────────
# Public URL of your deployed site — no trailing slash
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com

# Strong random string used to sign Payload JWTs and encrypt tokens
# Generate one with: openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-strong-random-secret

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# In Dokploy, create a PostgreSQL service and use its internal connection string.
# e.g. postgresql://payload:password@postgres:5432/payload
DATABASE_URL=postgresql://payload:payload@localhost:5432/payload

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
# Create an R2 bucket in Cloudflare, then generate an API token with
# Object Read & Write permissions.
S3_BUCKET=your-r2-bucket-name
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Public URL used to serve uploaded media files.
# Enable "Public Access" in the Cloudflare dashboard to get this URL.
S3_PUBLIC_URL=https://pub-<hash>.r2.dev

# If you use a custom domain instead of *.r2.dev, set the hostname here so
# Next.js Image Optimisation can fetch it:
# S3_CDN_HOSTNAME=media.yourdomain.com

# ─── Optional SEO ─────────────────────────────────────────────────────────────
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
